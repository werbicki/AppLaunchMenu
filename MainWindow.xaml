<?xml version="1.0" encoding="utf-8" ?>
<local:WindowNotifyPropertyChanged
    x:Class="AppLaunchMenu.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AppLaunchMenu"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <local:WindowNotifyPropertyChanged.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </local:WindowNotifyPropertyChanged.SystemBackdrop>

    <Grid x:Name="RootElement">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBar">
            <Image
                x:Name="TitleBarIcon"
                Grid.Column="1"
                Width="16"
                Height="16"
                Margin="8,0,4,0"
                Source="ms-appx:///Assets/StoreLogo.png" />
            <TextBlock
                x:Name="TitleBarTextBlock"
                Grid.Column="2"
                VerticalAlignment="Center"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind AppTitle, Mode=OneWay}" />
        </Grid>

        <Frame x:Name="InnerFrame" Grid.Row="1" />
    </Grid>

</local:WindowNotifyPropertyChanged>
